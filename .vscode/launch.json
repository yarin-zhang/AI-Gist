{
    // 使用 IntelliSense 了解相关属性。 
    // 悬停以查看现有属性的描述。
    // 欲了解更多信息，请访问: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "开发模式 (yarn dev)",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/dev-server.js",
            "cwd": "${workspaceFolder}",
            "console": "internalConsole",
            "outputCapture": "std",
            "env": {
                "NODE_ENV": "development"
            }
        },
        {
            "name": "构建项目 (yarn build)",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/build.js",
            "cwd": "${workspaceFolder}",
            "console": "internalConsole",
            "outputCapture": "std",
            "env": {
                "NODE_ENV": "production"
            }
        },
        {
            "name": "运行测试 (yarn test)",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/node_modules/.bin/vitest",
            "cwd": "${workspaceFolder}",
            "console": "internalConsole",
            "outputCapture": "std",
            "env": {
                "NODE_ENV": "test"
            }
        },
        {
            "name": "移动端 - 构建并打开 iOS",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/build-mobile.js",
            "cwd": "${workspaceFolder}",
            "console": "internalConsole",
            "outputCapture": "std",
            "postDebugTask": "打开 iOS 项目",
            "env": {
                "NODE_ENV": "production",
                "PATH": "${env:PATH}:${workspaceFolder}/node_modules/.bin"
            }
        },
        {
            "name": "移动端 - 构建并打开 Android",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/build-mobile.js",
            "cwd": "${workspaceFolder}",
            "console": "internalConsole",
            "outputCapture": "std",
            "postDebugTask": "打开 Android 项目",
            "env": {
                "NODE_ENV": "production",
                "PATH": "${env:PATH}:${workspaceFolder}/node_modules/.bin"
            }
        }
    ]
}