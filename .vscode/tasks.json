{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "开发模式",
            "type": "shell",
            "command": "yarn",
            "args": ["dev"],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "isBackground": true
        },
        {
            "label": "构建项目",
            "type": "shell",
            "command": "yarn",
            "args": ["build"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "运行测试",
            "type": "shell",
            "command": "yarn",
            "args": ["test"],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "构建移动端",
            "type": "shell",
            "command": "yarn",
            "args": ["build:mobile"],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            }
        },
        {
            "label": "打开 iOS 项目",
            "type": "shell",
            "command": "yarn",
            "args": ["cap:ios"],
            "group": "build",
            "presentation": {
                "reveal": "never",
                "panel": "shared"
            }
        },
        {
            "label": "打开 Android 项目",
            "type": "shell",
            "command": "yarn",
            "args": ["cap:android"],
            "group": "build",
            "presentation": {
                "reveal": "never",
                "panel": "shared"
            }
        }
    ]
}
